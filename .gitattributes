# Normalize line endings
* text=auto

# C# / WinUI — keep CRLF on Windows, LF on Linux/macOS CI
windows/**/*.cs    text eol=crlf
windows/**/*.xaml  text eol=crlf
windows/**/*.csproj text eol=crlf
windows/**/*.sln   text eol=crlf

# CI workflows always LF
.github/**/*.yml   text eol=lf

# Release source archives should not include review handoff state or the
# PKGBUILD that checksums the archive itself.
.review export-ignore
.review/** export-ignore
pkg/arch/PKGBUILD export-ignore

# Binaries
windows/**/*.png   binary
windows/**/*.ico   binary
