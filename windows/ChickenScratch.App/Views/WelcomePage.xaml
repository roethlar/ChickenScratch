<UserControl
    x:Class="ChickenScratch.App.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520" Spacing="24" Padding="40">

            <!-- Logo / Title -->
            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="ChickenScratch"
                           Style="{StaticResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Where messy drafts become masterpieces"
                           Style="{StaticResource BodyTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Opacity="0.6" />
            </StackPanel>

            <!-- Pandoc warning -->
            <InfoBar x:Name="PandocWarning"
                     IsOpen="False"
                     Severity="Warning"
                     Title="Pandoc not found"
                     Message="Scrivener import and manuscript export require Pandoc. Install from pandoc.org or via: winget install pandoc" />

            <!-- Error banner -->
            <InfoBar x:Name="ErrorBar"
                     IsOpen="False"
                     Severity="Error"
                     IsClosable="True" />

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Click="OpenProject_Click"
                        Style="{StaticResource WelcomeActionButtonStyle}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xED25;" FontSize="28" />
                        <TextBlock Text="Open Project" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Click="NewProject_Click"
                        Style="{StaticResource WelcomeActionButtonStyle}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE8A5;" FontSize="28" />
                        <TextBlock Text="New Project" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Click="ImportScrivener_Click"
                        Style="{StaticResource WelcomeActionButtonStyle}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE8B5;" FontSize="28" />
                        <TextBlock Text="Import Scrivener" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Recent projects -->
            <StackPanel x:Name="RecentPanel" Spacing="4">
                <TextBlock Text="Recent Projects"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,0,0,8" />
                <ItemsControl x:Name="RecentList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="RecentItem_Click" Tag="{Binding Path}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Style="{StaticResource TransparentButtonStyle}"
                                    Padding="8,6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource BodyTextBlockStyle}" />
                                        <TextBlock Text="{Binding Path}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Opacity="0.5"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <FontIcon Grid.Column="1" Glyph="&#xE76C;"
                                              FontSize="12" Opacity="0.4"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
