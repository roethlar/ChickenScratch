<ContentDialog
    x:Class="ChickenScratch.App.Views.CompileDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Compile Manuscript"
    PrimaryButtonText="Compile"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="Compile_Click"
    MinWidth="500">

    <StackPanel Spacing="14">

        <!-- Format -->
        <StackPanel Spacing="4">
            <TextBlock Text="Output Format" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
            <ComboBox x:Name="FormatBox" HorizontalAlignment="Stretch" SelectedIndex="0">
                <ComboBoxItem Content="Word Document (.docx)" Tag="docx" />
                <ComboBoxItem Content="EPUB (.epub)"          Tag="epub" />
                <ComboBoxItem Content="HTML (.html)"          Tag="html" />
                <ComboBoxItem Content="OpenDocument (.odt)"   Tag="odt" />
            </ComboBox>
        </StackPanel>

        <!-- Output path -->
        <StackPanel Spacing="4">
            <TextBlock Text="Save As" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" x:Name="OutputPathBox" IsReadOnly="True"
                         PlaceholderText="Choose output location…" />
                <Button Grid.Column="1" Content="Browse…" Click="BrowseOutput_Click" />
            </Grid>
        </StackPanel>

        <!-- Title / Author -->
        <StackPanel Spacing="4">
            <TextBlock Text="Title (optional)" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
            <TextBox x:Name="TitleBox" PlaceholderText="Leave blank to omit from title page" />
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Author (optional)" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
            <TextBox x:Name="AuthorBox" PlaceholderText="Leave blank to omit" />
        </StackPanel>

        <!-- Options -->
        <CheckBox x:Name="IncludeTitlePageBox" Content="Include title page" IsChecked="True" />

        <StackPanel Spacing="4">
            <TextBlock Text="Section Separator" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
            <TextBox x:Name="SeparatorBox" Text="* * *" />
        </StackPanel>

        <!-- Status row -->
        <StackPanel x:Name="StatusArea" Spacing="8" Orientation="Horizontal" Visibility="Collapsed">
            <ProgressRing x:Name="CompileProgress" IsActive="True"
                          Width="20" Height="20" Visibility="Collapsed" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
        </StackPanel>

    </StackPanel>
</ContentDialog>
