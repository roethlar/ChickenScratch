<ContentDialog
    x:Class="ChickenScratch.App.Views.StatsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Statistics"
    CloseButtonText="Close"
    MinWidth="480">

    <StackPanel Spacing="16">

        <!-- Summary tiles -->
        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="6" Padding="12,10">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="TotalWordsText"
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Words" Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center" Opacity="0.6" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="6" Padding="12,10">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="PageCountText"
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Pages" Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center" Opacity="0.6" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="6" Padding="12,10">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="ReadingMinText"
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Min. Read" Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center" Opacity="0.6" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="6" Padding="12,10">
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="DocCountText"
                               Style="{StaticResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Documents" Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center" Opacity="0.6" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Per-document table -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="6" Height="260">
            <Grid RowDefinitions="Auto,*">

                <!-- Header row -->
                <Grid Grid.Row="0" Padding="12,8" ColumnDefinitions="*,80">
                    <TextBlock Grid.Column="0" Text="DOCUMENT"
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.5" />
                    <TextBlock Grid.Column="1" Text="WORDS"
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.5"
                               TextAlignment="Right" />
                </Grid>

                <ListView x:Name="DocList" Grid.Row="1"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ItemContainerStyle="{StaticResource DefaultListViewItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,80" Padding="0,2">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Words}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextAlignment="Right"
                                           Opacity="0.7" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

    </StackPanel>
</ContentDialog>
