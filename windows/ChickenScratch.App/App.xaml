<Application
    x:Class="ChickenScratch.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:ChickenScratch.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/AppTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />
            <conv:NodeIconConverter x:Key="NodeIconConverter" />
            <conv:WordCountConverter x:Key="WordCountConverter" />
            <conv:SaveStatusConverter x:Key="SaveStatusConverter" />
            <conv:NotNullToBoolConverter x:Key="NotNullToBoolConverter" />
            <conv:TimestampConverter x:Key="TimestampConverter" />
            <conv:FileDiffStatusConverter x:Key="FileDiffStatusConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
