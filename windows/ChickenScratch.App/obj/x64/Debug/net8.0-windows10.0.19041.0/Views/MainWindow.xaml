<Window x:ConnectionId='1'
    x:Class="ChickenScratch.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ChickenScratch.App.Controls"
    xmlns:views="using:ChickenScratch.App.Views"
    Title="ChickenScratch">

    <Grid x:ConnectionId='2' x:Name="RootGrid" RowDefinitions="Auto,*,Auto">

        <!-- Custom Title Bar -->
        <Grid x:ConnectionId='3' x:Name="AppTitleBar" Grid.Row="0" Height="48" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="ChickenScratch"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" Margin="16,0,0,0" Opacity="0.8" />

            <TextBlock x:ConnectionId='13' Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                          
                       Opacity="0.9" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                <Button x:ConnectionId='14'                           
                        ToolTipService.ToolTip="Toggle Binder"
                        Style="{StaticResource TransparentButtonStyle}">
                    <FontIcon Glyph="&#xE700;" FontSize="14" />
                </Button>
                <Button x:ConnectionId='15'                              
                        ToolTipService.ToolTip="Toggle Inspector"
                        Style="{StaticResource TransparentButtonStyle}">
                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                </Button>
                <Button x:ConnectionId='16'                           
                        ToolTipService.ToolTip="Save Revision"
                        Style="{StaticResource TransparentButtonStyle}">
                    <FontIcon Glyph="&#xE74E;" FontSize="14" />
                </Button>
                <Button x:ConnectionId='17'                           
                        ToolTipService.ToolTip="Settings"
                        Style="{StaticResource TransparentButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Three-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:ConnectionId='7' x:Name="BinderColumn" Width="240" MinWidth="0" MaxWidth="480" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition x:ConnectionId='8' x:Name="InspectorColumn" Width="260" MinWidth="0" MaxWidth="420" />
            </Grid.ColumnDefinitions>

            <!-- Binder -->
            <controls:BinderControl x:ConnectionId='9' Grid.Column="0"
                x:Name="BinderPanel"
                                                                  
                                                           />

            <Border Grid.Column="1" Width="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Editor / Welcome -->
            <Grid Grid.Column="2">
                <views:WelcomePage x:ConnectionId='11' x:Name="WelcomePanel"
                                                                                  
                                                         
                                                            />

                <controls:EditorControl x:ConnectionId='12' x:Name="EditorPanel"
                                                                      
                                                                                  />
            </Grid>

            <Border Grid.Column="3" Width="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Inspector -->
            <controls:InspectorControl x:ConnectionId='10' Grid.Column="4"
                x:Name="InspectorPanel"
                                                                      />
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Height="28"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:ConnectionId='4' Grid.Column="0" VerticalAlignment="Center"
                                                                               
                           Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <TextBlock x:ConnectionId='5' Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"
                                                                                           />
                    <TextBlock x:ConnectionId='6' Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"
                                                                                            />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>

