<UserControl x:ConnectionId='1'
    x:Class="ChickenScratch.App.Controls.EditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ChickenScratch.App.ViewModels">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Formatting toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Collapsed"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
            <AppBarToggleButton x:ConnectionId='8' x:Name="BoldBtn" Icon="Bold" Label="Bold"
                                                                                  
                                                   KeyboardAcceleratorPlacementMode="Hidden" />
            <AppBarToggleButton x:ConnectionId='9' x:Name="ItalicBtn" Icon="Italic" Label="Italic"
                                                                                    
                                                     />
            <AppBarToggleButton x:ConnectionId='10' x:Name="UnderlineBtn" Icon="Underline" Label="Underline"
                                                                                       
                                                        />
            <AppBarSeparator />
            <AppBarButton x:ConnectionId='11' Label="H1"                 >
                <AppBarButton.Icon><FontIcon Glyph="&#xE8D2;" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:ConnectionId='12' Label="H2"                 >
                <AppBarButton.Icon><FontIcon Glyph="&#xE8D3;" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:ConnectionId='13' Label="H3"                 >
                <AppBarButton.Icon><FontIcon Glyph="&#xE8D4;" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton x:ConnectionId='14' Icon="Undo" Label="Undo"                    />
            <AppBarButton x:ConnectionId='15' Icon="Redo" Label="Redo"                    />
            <AppBarSeparator />
            <AppBarButton x:ConnectionId='16' Icon="Find" Label="Find"                    />
        </CommandBar>

        <!-- Find bar (collapsed by default) -->
        <Grid x:ConnectionId='2' x:Name="FindBar" Grid.Row="1" Visibility="Collapsed"
              Padding="12,6" ColumnDefinitions="*,Auto,Auto,Auto"
              Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBox x:ConnectionId='4' Grid.Column="0" x:Name="FindBox"
                     PlaceholderText="Find in document…"
                                                      
                                               />
            <TextBox x:ConnectionId='5' Grid.Column="1" x:Name="ReplaceBox"
                     PlaceholderText="Replace with…"
                     Margin="8,0,0,0" />
            <Button x:ConnectionId='6' Grid.Column="2" Content="Replace" Margin="8,0,0,0"
                                          />
            <Button x:ConnectionId='7' Grid.Column="3" Content="✕" Margin="8,0,0,0"
                    Style="{StaticResource TransparentButtonStyle}"
                                            />
        </Grid>

        <!-- WebView2 editor -->
        <Border Grid.Row="2" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <!-- WebView2 is added programmatically in code-behind -->
            <ContentPresenter x:ConnectionId='3' x:Name="WebViewHost" />
        </Border>
    </Grid>
</UserControl>

