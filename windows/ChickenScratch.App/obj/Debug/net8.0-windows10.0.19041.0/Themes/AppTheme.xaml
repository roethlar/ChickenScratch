<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="BinderDefaultWidth">240</x:Double>
    <x:Double x:Key="InspectorDefaultWidth">260</x:Double>
    <x:Double x:Key="StatusBarHeight">28</x:Double>

    <Style x:Key="BinderTreeViewItemStyle" TargetType="TreeViewItem">
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style x:Key="WelcomeActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="MinWidth" Value="160" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

</ResourceDictionary>

