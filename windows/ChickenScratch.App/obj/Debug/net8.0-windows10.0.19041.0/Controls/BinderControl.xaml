<UserControl x:ConnectionId='1'
    x:Class="ChickenScratch.App.Controls.BinderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ChickenScratch.App.ViewModels">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Grid Grid.Row="0" Padding="8,6" ColumnDefinitions="*,Auto,Auto,Auto"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">

            <TextBlock Grid.Column="0" Text="Binder"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       VerticalAlignment="Center" Margin="4,0,0,0" />

            <Button x:ConnectionId='12' Grid.Column="1"                          
                    ToolTipService.ToolTip="New Document"
                    Style="{StaticResource TransparentButtonStyle}" Padding="6">
                <FontIcon Glyph="&#xE8A5;" FontSize="14" />
            </Button>
            <Button x:ConnectionId='13' Grid.Column="2"                        
                    ToolTipService.ToolTip="New Folder"
                    Style="{StaticResource TransparentButtonStyle}" Padding="6">
                <FontIcon Glyph="&#xE8F4;" FontSize="14" />
            </Button>
            <Button x:ConnectionId='14' Grid.Column="3"                     
                    ToolTipService.ToolTip="Delete"
                    Style="{StaticResource TransparentButtonStyle}" Padding="6">
                <FontIcon Glyph="&#xE74D;" FontSize="14" />
            </Button>
        </Grid>

        <!-- Tree -->
        <TreeView x:ConnectionId='2' Grid.Row="1" x:Name="BinderTree"
                                                                     
                  SelectionMode="Single"
                  CanDragItems="True" CanReorderItems="True" AllowDrop="True"
                                                
                  Padding="4,4">

            <TreeView.ItemTemplate>
                <DataTemplate                                    >
                    <TreeViewItem x:ConnectionId='4'                                
                                  IsExpanded="True"
                                  Style="{StaticResource BinderTreeViewItemStyle}">
                        <TreeViewItem.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:ConnectionId='5' Text="New Document"                            
                                                                 >
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A5;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='6' Text="New Folder"                               
                                                                 >
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8F4;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem x:ConnectionId='7' Text="Rename"                            
                                                                 >
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='8' Text="Delete"                            
                                                                 >
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </TreeViewItem.ContextFlyout>

                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,1">
                            <!-- Icon -->
                            <FontIcon x:ConnectionId='9' Grid.Column="0"
                                                                                                               
                                      FontSize="13" Margin="0,0,6,0" Opacity="0.7" />

                            <!-- Name (display) -->
                            <TextBlock x:ConnectionId='10' Grid.Column="1"
                                                                        
                                       TextTrimming="CharacterEllipsis"
                                                                                                                                                 />

                            <!-- Name (editing) -->
                            <TextBox x:ConnectionId='11' Grid.Column="1"
                                                                                                               
                                                                                                                                       
                                                                
                                                                    
                                                       />
                        </Grid>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>

