<UserControl
    x:Class="ChickenScratch.App.Controls.InspectorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ChickenScratch.App.ViewModels">

    <Grid RowDefinitions="Auto,*"
          Background="{ThemeResource LayerFillColorDefaultBrush}"
          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
          BorderThickness="1,0,0,0">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="12,8"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock Text="Inspector"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      IsEnabled="{x:Bind ViewModel.HasDocument, Mode=OneWay}">
            <StackPanel Padding="12,8" Spacing="16">

                <!-- Synopsis -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Synopsis" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                    <TextBox Text="{x:Bind ViewModel.Synopsis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Brief summary…"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             MaxHeight="160" />
                </StackPanel>

                <!-- Label -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Label" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                    <ComboBox SelectedValue="{x:Bind ViewModel.Label, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="" />
                        <ComboBoxItem Content="Scene" />
                        <ComboBoxItem Content="Chapter" />
                        <ComboBoxItem Content="Part" />
                        <ComboBoxItem Content="Note" />
                        <ComboBoxItem Content="Research" />
                    </ComboBox>
                </StackPanel>

                <!-- Status -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Status" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                    <ComboBox SelectedValue="{x:Bind ViewModel.Status, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="" />
                        <ComboBoxItem Content="To Do" />
                        <ComboBoxItem Content="In Progress" />
                        <ComboBoxItem Content="First Draft" />
                        <ComboBoxItem Content="Revised Draft" />
                        <ComboBoxItem Content="Final Draft" />
                        <ComboBoxItem Content="Done" />
                    </ComboBox>
                </StackPanel>

                <!-- Include in compile -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Include in Compile"
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                    <ToggleSwitch IsOn="{x:Bind ViewModel.IncludeInCompile, Mode=TwoWay}"
                                  OnContent="Yes" OffContent="No" />
                </StackPanel>

                <!-- Word count target -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Word Count Target"
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                    <NumberBox Value="{x:Bind ViewModel.WordCountTargetDouble, Mode=TwoWay}"
                               Minimum="0" Maximum="999999"
                               SpinButtonPlacementMode="Compact"
                               PlaceholderText="0 = no target" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
